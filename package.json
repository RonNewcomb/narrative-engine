{
  "name": "narrative-engine",
  "type": "module",
  "prettier": {
    "printWidth": 140,
    "arrowParens": "avoid"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "peggy": "^4.0.3",
    "rd-parse": "^3.4.0",
    "rd-parse-jsexpr": "^3.2.0",
    "typescript": "^5.5.4",
    "vite": "^6.4.2"
  },
  "scripts": {
    "publish2": "cd publishing && node publish.ts && cd ..",
    "parser": "cd system3 && peggy --format es -o parser.js parser.peggy && node compile.ts ../app3/system3.sample.txt",
    "publish": "cd app3 && node ../system3/publish.ts system3.sample.txt && cd ..",
    "serve": "cd app3/dist && vite serve --host"
  }
}
