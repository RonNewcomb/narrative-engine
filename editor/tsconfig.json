{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "dom",
      "DOM.Iterable"
    ],
    "module": "esnext",
    "target": "esnext",
    "outDir": "build",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": [
    "**/*.tsx",
    "**/*.ts",
    "window.d.ts",
    "elements.d.ts"
  ]
}