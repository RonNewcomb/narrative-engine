{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "dom",
      "DOM.Iterable"
    ],
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.ts",
    "components/*.ts",
    "window.d.ts",
  ]
}